FLASK_ENV=development
FLASK_DEBUG=1

# MongoDB (local or Atlas) — use your own URI
MONGO_URI=mongodb://localhost:27017/intelliguard

JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_HOURS=24

EMAIL_USER=
EMAIL_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

DAILY_ALERT_HOUR=7
DAILY_ALERT_MINUTE=0

# TTL (seconds) for automatic expiry of predictions and alerts (default 3 days)
PREDICTION_TTL_SECONDS=259200
ALERT_TTL_SECONDS=259200

# OpenWeather + Redis weather cache
OPENWEATHER_API_KEY=your_openweather_api_key
REDIS_URL=redis://localhost:6379/0
WEATHER_CACHE_TTL_SECONDS=600
PREDICTION_REFRESH_MINUTES=10
